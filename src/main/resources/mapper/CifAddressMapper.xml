<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.address.repository.CifAddressMapper">

    <!-- 缓存配置（可选，根据需要启用） -->
    <!-- <cache eviction="LRU" size="128" flushInterval="60000" readOnly="true"/> -->

    <!-- 结果映射：Java属性与数据库列的映射关系 -->
    <resultMap id="CifAddressResultMap" type="CifAddress">
        <!-- 主键字段 -->
        <id property="seqNo" column="SEQ_NO" jdbcType="VARCHAR"/>
        <!-- 普通字段 -->
        <result property="clientNo" column="CLIENT_NO" jdbcType="VARCHAR"/>
        <result property="addressType" column="ADDRESS_TYPE" jdbcType="VARCHAR"/>
        <result property="addressDetail" column="ADDRESS_DETAIL" jdbcType="VARCHAR"/>
        <!-- 日期字段：允许为null，必须指定jdbcType -->
        <result property="lastChangeDate" column="LAST_CHANGE_DATE" jdbcType="TIMESTAMP"/>
        <!-- CHAR(1) 字段统一指定jdbcType避免类型转换问题 -->
        <result property="isMailingAddress" column="IS_MAILING_ADDRESS" jdbcType="CHAR"/>
        <result property="isNewest" column="IS_NEWEST" jdbcType="CHAR"/>
        <result property="delFlag" column="DEL_FLAG" jdbcType="CHAR"/>
    </resultMap>

    <!-- 查询：按客户号查询地址列表 -->
    <select id="findByClientNo" resultMap="CifAddressResultMap">
        SELECT
            SEQ_NO,
            CLIENT_NO,
            ADDRESS_TYPE,
            ADDRESS_DETAIL,
            LAST_CHANGE_DATE,
            IS_MAILING_ADDRESS,
            IS_NEWEST,
            DEL_FLAG
        FROM CIF_ADDRESS
        <where>
            <if test="clientNo != null and clientNo != ''">
                AND CLIENT_NO = #{clientNo,jdbcType=VARCHAR}
            </if>
            <if test="delFlag != null and delFlag != ''">
                AND DEL_FLAG = #{delFlag,jdbcType=CHAR}
            </if>
        </where>
    </select>

    <!-- 插入：单条记录（使用 trim 去除多余逗号） -->
    <insert id="save" parameterType="CifAddress">
        INSERT INTO CIF_ADDRESS
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="seqNo != null and seqNo != ''">SEQ_NO,</if>
            <if test="clientNo != null and clientNo != ''">CLIENT_NO,</if>
            <if test="addressType != null and addressType != ''">ADDRESS_TYPE,</if>
            <if test="addressDetail != null and addressDetail != ''">ADDRESS_DETAIL,</if>
            <if test="lastChangeDate != null">LAST_CHANGE_DATE,</if>
            <if test="isMailingAddress != null and isMailingAddress != ''">IS_MAILING_ADDRESS,</if>
            <if test="isNewest != null and isNewest != ''">IS_NEWEST,</if>
            <if test="delFlag != null and delFlag != ''">DEL_FLAG,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="seqNo != null and seqNo != ''">#{seqNo,jdbcType=VARCHAR},</if>
            <if test="clientNo != null and clientNo != ''">#{clientNo,jdbcType=VARCHAR},</if>
            <if test="addressType != null and addressType != ''">#{addressType,jdbcType=VARCHAR},</if>
            <if test="addressDetail != null and addressDetail != ''">#{addressDetail,jdbcType=VARCHAR},</if>
            <if test="lastChangeDate != null">#{lastChangeDate,jdbcType=TIMESTAMP},</if>
            <if test="isMailingAddress != null and isMailingAddress != ''">#{isMailingAddress,jdbcType=CHAR},</if>
            <if test="isNewest != null and isNewest != ''">#{isNewest,jdbcType=CHAR},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag,jdbcType=CHAR},</if>
        </trim>
    </insert>

    <!-- 更新：单条记录（使用 set 标签自动去除末尾逗号） -->
    <update id="update" parameterType="CifAddress">
        UPDATE CIF_ADDRESS
        <set>
            <if test="addressType != null and addressType != ''">
                ADDRESS_TYPE = #{addressType,jdbcType=VARCHAR},
            </if>
            <if test="addressDetail != null and addressDetail != ''">
                ADDRESS_DETAIL = #{addressDetail,jdbcType=VARCHAR},
            </if>
            <if test="lastChangeDate != null">
                LAST_CHANGE_DATE = #{lastChangeDate,jdbcType=TIMESTAMP},
            </if>
            <if test="isMailingAddress != null and isMailingAddress != ''">
                IS_MAILING_ADDRESS = #{isMailingAddress,jdbcType=CHAR},
            </if>
            <if test="isNewest != null and isNewest != ''">
                IS_NEWEST = #{isNewest,jdbcType=CHAR},
            </if>
            <if test="delFlag != null and delFlag != ''">
                DEL_FLAG = #{delFlag,jdbcType=CHAR},
            </if>
        </set>
        WHERE SEQ_NO = #{seqNo,jdbcType=VARCHAR}
    </update>

    <!-- 批量插入：使用 foreach -->
    <insert id="saveAll" parameterType="java.util.List">
        INSERT INTO CIF_ADDRESS (
            SEQ_NO,
            CLIENT_NO,
            ADDRESS_TYPE,
            ADDRESS_DETAIL,
            LAST_CHANGE_DATE,
            IS_MAILING_ADDRESS,
            IS_NEWEST,
            DEL_FLAG
        ) VALUES
        <foreach collection="list" item="addr" separator=",">
            (
                #{addr.seqNo,jdbcType=VARCHAR},
                #{addr.clientNo,jdbcType=VARCHAR},
                #{addr.addressType,jdbcType=VARCHAR},
                #{addr.addressDetail,jdbcType=VARCHAR},
                #{addr.lastChangeDate,jdbcType=TIMESTAMP},
                #{addr.isMailingAddress,jdbcType=CHAR},
                #{addr.isNewest,jdbcType=CHAR},
                #{addr.delFlag,jdbcType=CHAR}
            )
        </foreach>
    </insert>

    <!-- 批量更新：使用 foreach（需要数据库支持 multiStatements） -->
    <update id="updateAll" parameterType="java.util.List">
        <foreach collection="list" item="addr">
            UPDATE CIF_ADDRESS
            <set>
                <if test="addr.addressType != null and addr.addressType != ''">
                    ADDRESS_TYPE = #{addr.addressType,jdbcType=VARCHAR},
                </if>
                <if test="addr.addressDetail != null and addr.addressDetail != ''">
                    ADDRESS_DETAIL = #{addr.addressDetail,jdbcType=VARCHAR},
                </if>
                <if test="addr.lastChangeDate != null">
                    LAST_CHANGE_DATE = #{addr.lastChangeDate,jdbcType=TIMESTAMP},
                </if>
                <if test="addr.isMailingAddress != null and addr.isMailingAddress != ''">
                    IS_MAILING_ADDRESS = #{addr.isMailingAddress,jdbcType=CHAR},
                </if>
                <if test="addr.isNewest != null and addr.isNewest != ''">
                    IS_NEWEST = #{addr.isNewest,jdbcType=CHAR},
                </if>
                <if test="addr.delFlag != null and addr.delFlag != ''">
                    DEL_FLAG = #{addr.delFlag,jdbcType=CHAR},
                </if>
            </set>
            WHERE SEQ_NO = #{addr.seqNo,jdbcType=VARCHAR};
        </foreach>
    </update>

</mapper>
