{
  "permissions": {
    "allow": [
      "Bash(cd *)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(mvn test *)",
      "Bash(mvn clean *)",
      "Bash(mvn compile *)",
      "Bash(MAVEN_OPTS=\"-Xmx512m\" mvn test -Dtest=AddressMergerTest -DskipTests=false)",
      "Bash(xargs wc *)",
      "Bash(git -C *)",
      "Bash(mvn dependency:resolve *)",
      "Bash(mvn test-compile *)",
      "Bash(mvn *)",
      "Bash(xmllint *)"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
